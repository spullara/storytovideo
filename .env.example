# API Keys for storytovideo CLI
# Copy this file to .env and fill in your actual API keys

# Anthropic API key for Claude Opus 4.6 orchestrator
ANTHROPIC_API_KEY=your-anthropic-api-key

# Reve API key for image generation
REVE_API_KEY=your-reve-api-key

# Google Gemini API key (for Veo 3.1 video generation)
GEMINI_API_KEY=your-gemini-api-key

# Video generation backend: "veo" (default) or "comfy"
# - veo: Uses Google Veo 3.1 via Gemini API (requires GEMINI_API_KEY)
# - comfy: Uses ComfyUI frame_to_video workflow (requires COMFYUI_API_URL)
VIDEO_BACKEND=veo

